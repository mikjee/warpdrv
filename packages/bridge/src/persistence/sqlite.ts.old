// ============================================================
// warpbridge/src/persistence/sqlite.ts
// SQLite persistence using sql.js. Node only.
// Schema mirrors WarpCore's chat.db. Table prefix configurable.
// ============================================================

import initSqlJs, { type Database } from 'sql.js';
import fs from 'fs';
import path from 'path';
import type { IPersistence } from '../types/interfaces';
import type {
	IFolder,
	IChatThread,
	IThreadConfig,
	IChatMessage,
	IMessagePart,
	IToolCall,
	IServerPermission,
	IToolPermission,
	TFolderId,
	TThreadId,
	TMessageId,
	TToolCallId,
} from '../types';
import {
	EChatRole,
	EMessagePartType,
	EToolApprovalMode,
	EToolCallStatus,
} from '../types';

export interface ISqlitePersistenceOptions {
	/** Prefix prepended to all table names. Default: '' (matches WarpCore). */
	tablePrefix?: string;
}

// ============================================================
// Table name helpers — build schema and queries from prefix
// ============================================================
function buildTableNames(prefix: string) {
	return {
		folders: `${prefix}folders`,
		threads: `${prefix}threads`,
		threadConfigs: `${prefix}thread_configs`,
		messages: `${prefix}messages`,
		messageParts: `${prefix}message_parts`,
		toolCalls: `${prefix}tool_calls`,
		serverPermissions: `${prefix}mcp_server_permissions`,
		toolPermissions: `${prefix}mcp_tool_permissions`,
	};
}

function buildSchema(t: ReturnType<typeof buildTableNames>): string {
	return `
		CREATE TABLE IF NOT EXISTS ${t.folders} (
			id TEXT PRIMARY KEY,
			name TEXT NOT NULL,
			parentId TEXT,
			sortOrder INTEGER NOT NULL DEFAULT 0,
			createdAt INTEGER NOT NULL,
			FOREIGN KEY (parentId) REFERENCES ${t.folders}(id) ON DELETE SET NULL
		);

		CREATE TABLE IF NOT EXISTS ${t.threads} (
			id TEXT PRIMARY KEY,
			title TEXT NOT NULL DEFAULT 'New Chat',
			folderId TEXT,
			systemPrompt TEXT NOT NULL DEFAULT '',
			meta TEXT NOT NULL DEFAULT '{}',
			createdAt INTEGER NOT NULL,
			updatedAt INTEGER NOT NULL,
			FOREIGN KEY (folderId) REFERENCES ${t.folders}(id) ON DELETE SET NULL
		);

		CREATE TABLE IF NOT EXISTS ${t.threadConfigs} (
			threadId TEXT PRIMARY KEY,
			presetId TEXT,
			systemPrompt TEXT NOT NULL DEFAULT '',
			params TEXT NOT NULL DEFAULT '{}',
			FOREIGN KEY (threadId) REFERENCES ${t.threads}(id) ON DELETE CASCADE
		);

		CREATE TABLE IF NOT EXISTS ${t.messages} (
			id TEXT PRIMARY KEY,
			parentId TEXT,
			threadId TEXT NOT NULL,
			role TEXT NOT NULL,
			stats TEXT,
			createdAt INTEGER NOT NULL,
			FOREIGN KEY (threadId) REFERENCES ${t.threads}(id) ON DELETE CASCADE,
			FOREIGN KEY (parentId) REFERENCES ${t.messages}(id) ON DELETE SET NULL
		);

		CREATE TABLE IF NOT EXISTS ${t.messageParts} (
			id TEXT PRIMARY KEY,
			messageId TEXT NOT NULL,
			type TEXT NOT NULL,
			orderIndex INTEGER NOT NULL,
			text TEXT,
			toolCallId TEXT,
			FOREIGN KEY (messageId) REFERENCES ${t.messages}(id) ON DELETE CASCADE,
			FOREIGN KEY (toolCallId) REFERENCES ${t.toolCalls}(id) ON DELETE CASCADE
		);

		CREATE TABLE IF NOT EXISTS ${t.toolCalls} (
			id TEXT PRIMARY KEY,
			messageId TEXT NOT NULL,
			threadId TEXT NOT NULL,
			serverName TEXT NOT NULL,
			toolName TEXT NOT NULL,
			arguments TEXT NOT NULL DEFAULT '{}',
			result TEXT,
			status TEXT NOT NULL DEFAULT 'PENDING',
			error TEXT,
			createdAt INTEGER NOT NULL,
			resolvedAt INTEGER,
			FOREIGN KEY (threadId) REFERENCES ${t.threads}(id) ON DELETE CASCADE
		);

		CREATE TABLE IF NOT EXISTS ${t.serverPermissions} (
			serverName TEXT PRIMARY KEY,
			enabled INTEGER NOT NULL DEFAULT 1
		);

		CREATE TABLE IF NOT EXISTS ${t.toolPermissions} (
			serverName TEXT NOT NULL,
			toolName TEXT NOT NULL,
			enabled INTEGER NOT NULL DEFAULT 1,
			approvalMode TEXT NOT NULL DEFAULT 'ASK',
			PRIMARY KEY (serverName, toolName)
		);

		CREATE INDEX IF NOT EXISTS idx_${t.threads}_folder ON ${t.threads}(folderId);
		CREATE INDEX IF NOT EXISTS idx_${t.threads}_updated ON ${t.threads}(updatedAt);
		CREATE INDEX IF NOT EXISTS idx_${t.messages}_thread ON ${t.messages}(threadId, createdAt);
		CREATE INDEX IF NOT EXISTS idx_${t.messages}_parent ON ${t.messages}(parentId);
		CREATE INDEX IF NOT EXISTS idx_${t.messageParts}_message ON ${t.messageParts}(messageId, orderIndex);
		CREATE INDEX IF NOT EXISTS idx_${t.toolCalls}_message ON ${t.toolCalls}(messageId);
		CREATE INDEX IF NOT EXISTS idx_${t.toolCalls}_thread ON ${t.toolCalls}(threadId);
		CREATE INDEX IF NOT EXISTS idx_${t.toolCalls}_status ON ${t.toolCalls}(status);
	`;
}

// ============================================================
// SqlitePersistence
// ============================================================
export class SqlitePersistence implements IPersistence {
	private db: Database | null = null;
	private dbPath: string;
	private t: ReturnType<typeof buildTableNames>;

	constructor(dbPath: string, options: ISqlitePersistenceOptions = {}) {
		this.dbPath = dbPath;
		this.t = buildTableNames(options.tablePrefix ?? '');
	}

	async init(): Promise<void> {
		const SQL = await initSqlJs();
		if (fs.existsSync(this.dbPath)) {
			const fileBuffer = fs.readFileSync(this.dbPath);
			this.db = new SQL.Database(fileBuffer);
		} else {
			const dir = path.dirname(this.dbPath);
			if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
			this.db = new SQL.Database();
		}
		this.db.run('PRAGMA foreign_keys = ON');
		this.db.exec(buildSchema(this.t));
		this.save();
	}

	/** Writes the in-memory DB to disk. Called after every mutation. */
	private save(): void {
		if (!this.db) return;
		const data = this.db.export();
		fs.writeFileSync(this.dbPath, Buffer.from(data));
	}

	private run(sql: string, params: unknown[] = []): void {
		this.db!.run(sql, params as any[]);
		this.save();
	}

	private runNoSave(sql: string, params: unknown[] = []): void {
		this.db!.run(sql, params as any[]);
	}

	private transaction(fn: () => void): void {
		this.db!.run('BEGIN TRANSACTION');
		try {
			fn();
			this.db!.run('COMMIT');
			this.save();
		} catch (err) {
			this.db!.run('ROLLBACK');
			throw err;
		}
	}

	private get<T>(sql: string, params: unknown[] = []): T | null {
		const stmt = this.db!.prepare(sql);
		stmt.bind(params as any[]);
		if (stmt.step()) {
			const row = stmt.getAsObject() as T;
			stmt.free();
			return row;
		}
		stmt.free();
		return null;
	}

	private all<T>(sql: string, params: unknown[] = []): T[] {
		const stmt = this.db!.prepare(sql);
		stmt.bind(params as any[]);
		const results: T[] = [];
		while (stmt.step()) results.push(stmt.getAsObject() as T);
		stmt.free();
		return results;
	}

	// ============================================================
	// Folders
	// ============================================================
	async createFolder(folder: IFolder): Promise<void> {
		this.run(
			`INSERT INTO ${this.t.folders} (id, name, parentId, sortOrder, createdAt) VALUES (?, ?, ?, ?, ?)`,
			[folder.id, folder.name, folder.parentId, folder.sortOrder, folder.createdAt],
		);
	}

	async getFolder(id: TFolderId): Promise<IFolder | null> {
		return this.get<IFolder>(`SELECT * FROM ${this.t.folders} WHERE id = ?`, [id]);
	}

	async listFolders(): Promise<IFolder[]> {
		return this.all<IFolder>(`SELECT * FROM ${this.t.folders} ORDER BY sortOrder ASC, createdAt ASC`);
	}

	async updateFolder(id: TFolderId, updates: Partial<IFolder>): Promise<void> {
		const sets: string[] = [];
		const vals: unknown[] = [];
		if (updates.name !== undefined) { sets.push('name = ?'); vals.push(updates.name); }
		if (updates.parentId !== undefined) { sets.push('parentId = ?'); vals.push(updates.parentId); }
		if (updates.sortOrder !== undefined) { sets.push('sortOrder = ?'); vals.push(updates.sortOrder); }
		if (sets.length === 0) return;
		vals.push(id);
		this.run(`UPDATE ${this.t.folders} SET ${sets.join(', ')} WHERE id = ?`, vals);
	}

	async deleteFolder(id: TFolderId): Promise<void> {
		this.run(`DELETE FROM ${this.t.folders} WHERE id = ?`, [id]);
	}

	// ============================================================
	// Threads
	// ============================================================
	async createThread(thread: IChatThread): Promise<void> {
		this.run(
			`INSERT INTO ${this.t.threads} (id, title, folderId, systemPrompt, meta, createdAt, updatedAt) VALUES (?, ?, ?, ?, ?, ?, ?)`,
			[thread.id, thread.title, thread.folderId, thread.systemPrompt, thread.meta, thread.createdAt, thread.updatedAt],
		);
	}

	async getThread(id: TThreadId): Promise<IChatThread | null> {
		return this.get<IChatThread>(`SELECT * FROM ${this.t.threads} WHERE id = ?`, [id]);
	}

	async listThreads(): Promise<IChatThread[]> {
		return this.all<IChatThread>(`SELECT * FROM ${this.t.threads} ORDER BY updatedAt DESC`);
	}

	async updateThread(id: TThreadId, updates: Partial<IChatThread>): Promise<void> {
		const sets: string[] = [];
		const vals: unknown[] = [];
		if (updates.title !== undefined) { sets.push('title = ?'); vals.push(updates.title); }
		if (updates.folderId !== undefined) { sets.push('folderId = ?'); vals.push(updates.folderId); }
		if (updates.systemPrompt !== undefined) { sets.push('systemPrompt = ?'); vals.push(updates.systemPrompt); }
		if (updates.meta !== undefined) { sets.push('meta = ?'); vals.push(updates.meta); }
		sets.push('updatedAt = ?'); vals.push(Date.now());
		vals.push(id);
		this.run(`UPDATE ${this.t.threads} SET ${sets.join(', ')} WHERE id = ?`, vals);
	}

	async deleteThread(id: TThreadId): Promise<void> {
		this.run(`DELETE FROM ${this.t.threads} WHERE id = ?`, [id]);
	}

	// ============================================================
	// Thread Configs
	// ============================================================
	async getThreadConfig(threadId: TThreadId): Promise<IThreadConfig | null> {
		return this.get<IThreadConfig>(`SELECT * FROM ${this.t.threadConfigs} WHERE threadId = ?`, [threadId]);
	}

	async setThreadConfig(config: IThreadConfig): Promise<void> {
		const exists = this.get(`SELECT 1 FROM ${this.t.threadConfigs} WHERE threadId = ?`, [config.threadId]);
		if (exists) {
			this.run(
				`UPDATE ${this.t.threadConfigs} SET presetId = ?, systemPrompt = ?, params = ? WHERE threadId = ?`,
				[config.presetId, config.systemPrompt, config.params, config.threadId],
			);
		} else {
			this.run(
				`INSERT INTO ${this.t.threadConfigs} (threadId, presetId, systemPrompt, params) VALUES (?, ?, ?, ?)`,
				[config.threadId, config.presetId, config.systemPrompt, config.params],
			);
		}
	}

	async deleteThreadConfig(threadId: TThreadId): Promise<void> {
		this.run(`DELETE FROM ${this.t.threadConfigs} WHERE threadId = ?`, [threadId]);
	}

	// ============================================================
	// Messages (with parts)
	// ============================================================
	async createMessage(message: IChatMessage): Promise<void> {
		const stats = message.stats ? JSON.stringify(message.stats) : null;
		this.transaction(() => {
			this.runNoSave(
				`INSERT INTO ${this.t.messages} (id, parentId, threadId, role, stats, createdAt) VALUES (?, ?, ?, ?, ?, ?)`,
				[message.id, message.parentId ?? null, message.threadId, message.role, stats, message.createdAt],
			);
			for (const part of message.content) {
				this.insertPartNoSave(message.id, part);
			}
		});
	}

	async appendMessagePart(messageId: TMessageId, part: IMessagePart): Promise<void> {
		this.insertPartNoSave(messageId, part);
		this.save();
	}

	async deleteMessage(id: TMessageId): Promise<void> {
		this.run(`DELETE FROM ${this.t.messages} WHERE id = ?`, [id]);
	}

	async getMessages(threadId: TThreadId): Promise<IChatMessage[]> {
		const rows = this.all<any>(
			`SELECT * FROM ${this.t.messages} WHERE threadId = ? ORDER BY createdAt ASC`,
			[threadId],
		);
		return rows.map(r => this.hydrateMessage(r));
	}

	async getMessage(id: TMessageId): Promise<IChatMessage | null> {
		const row = this.get<any>(`SELECT * FROM ${this.t.messages} WHERE id = ?`, [id]);
		if (!row) return null;
		return this.hydrateMessage(row);
	}

	async updateMessage(id: TMessageId, updates: Partial<Pick<IChatMessage, 'stats'>>): Promise<void> {
		const sets: string[] = [];
		const vals: unknown[] = [];
		if (updates.stats !== undefined) {
			sets.push('stats = ?');
			vals.push(updates.stats ? JSON.stringify(updates.stats) : null);
		}
		if (sets.length === 0) return;
		vals.push(id);
		this.run(`UPDATE ${this.t.messages} SET ${sets.join(', ')} WHERE id = ?`, vals);
	}

	private insertPartNoSave(messageId: TMessageId, part: IMessagePart): void {
		const text = part.type === EMessagePartType.TEXT || part.type === EMessagePartType.REASONING
			? part.text
			: null;
		const toolCallId = part.type === EMessagePartType.TOOL_CALL ? part.toolCallId : null;
		this.runNoSave(
			`INSERT INTO ${this.t.messageParts} (id, messageId, type, orderIndex, text, toolCallId) VALUES (?, ?, ?, ?, ?, ?)`,
			[part.id, messageId, part.type, part.orderIndex, text, toolCallId],
		);
	}

	private hydrateMessage(row: any): IChatMessage {
		const partRows = this.all<any>(
			`SELECT * FROM ${this.t.messageParts} WHERE messageId = ? ORDER BY orderIndex ASC`,
			[row.id],
		);
		const content: IMessagePart[] = partRows.map(p => {
			if (p.type === EMessagePartType.TEXT) {
				return { id: p.id, type: EMessagePartType.TEXT, orderIndex: p.orderIndex, text: p.text ?? '' };
			}
			if (p.type === EMessagePartType.REASONING) {
				return { id: p.id, type: EMessagePartType.REASONING, orderIndex: p.orderIndex, text: p.text ?? '' };
			}
			return { id: p.id, type: EMessagePartType.TOOL_CALL, orderIndex: p.orderIndex, toolCallId: p.toolCallId };
		});
		return {
			id: row.id,
			parentId: row.parentId ?? null,
			threadId: row.threadId,
			role: row.role as EChatRole,
			content,
			stats: row.stats ? JSON.parse(row.stats) : null,
			createdAt: row.createdAt,
		};
	}

	// ============================================================
	// Tool Calls
	// ============================================================
	async createToolCall(toolCall: IToolCall): Promise<void> {
		this.run(
			`INSERT INTO ${this.t.toolCalls} (id, messageId, threadId, serverName, toolName, arguments, result, status, error, createdAt, resolvedAt)
			 VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
			[toolCall.id, toolCall.messageId, toolCall.threadId, toolCall.serverName, toolCall.toolName,
				toolCall.arguments, toolCall.result, toolCall.status, toolCall.error, toolCall.createdAt, toolCall.resolvedAt],
		);
	}

	async updateToolCall(id: TToolCallId, updates: Partial<IToolCall>): Promise<void> {
		const sets: string[] = [];
		const vals: unknown[] = [];
		if (updates.status !== undefined) { sets.push('status = ?'); vals.push(updates.status); }
		if (updates.result !== undefined) { sets.push('result = ?'); vals.push(updates.result); }
		if (updates.error !== undefined) { sets.push('error = ?'); vals.push(updates.error); }
		if (updates.resolvedAt !== undefined) { sets.push('resolvedAt = ?'); vals.push(updates.resolvedAt); }
		if (sets.length === 0) return;
		vals.push(id);
		this.run(`UPDATE ${this.t.toolCalls} SET ${sets.join(', ')} WHERE id = ?`, vals);
	}

	async getToolCall(id: TToolCallId): Promise<IToolCall | null> {
		return this.get<IToolCall>(`SELECT * FROM ${this.t.toolCalls} WHERE id = ?`, [id]);
	}

	async getToolCallsForThread(threadId: TThreadId): Promise<IToolCall[]> {
		return this.all<IToolCall>(
			`SELECT * FROM ${this.t.toolCalls} WHERE threadId = ? ORDER BY createdAt ASC`,
			[threadId],
		);
	}

	async getToolCallsForMessage(messageId: TMessageId): Promise<IToolCall[]> {
		return this.all<IToolCall>(
			`SELECT * FROM ${this.t.toolCalls} WHERE messageId = ? ORDER BY createdAt ASC`,
			[messageId],
		);
	}

	async getPendingToolCalls(): Promise<IToolCall[]> {
		return this.all<IToolCall>(
			`SELECT * FROM ${this.t.toolCalls} WHERE status = ? ORDER BY createdAt ASC`,
			[EToolCallStatus.PENDING],
		);
	}

	// ============================================================
	// Permissions — servers
	// ============================================================
	async getServerPermission(serverName: string): Promise<IServerPermission | null> {
		const row = this.get<{ serverName: string; enabled: number }>(
			`SELECT * FROM ${this.t.serverPermissions} WHERE serverName = ?`, [serverName],
		);
		if (!row) return null;
		return { serverName: row.serverName, enabled: row.enabled === 1 };
	}

	async setServerPermission(serverName: string, enabled: boolean): Promise<void> {
		const exists = this.get(`SELECT 1 FROM ${this.t.serverPermissions} WHERE serverName = ?`, [serverName]);
		if (exists) {
			this.run(`UPDATE ${this.t.serverPermissions} SET enabled = ? WHERE serverName = ?`, [enabled ? 1 : 0, serverName]);
		} else {
			this.run(`INSERT INTO ${this.t.serverPermissions} (serverName, enabled) VALUES (?, ?)`, [serverName, enabled ? 1 : 0]);
		}
	}

	async getAllServerPermissions(): Promise<IServerPermission[]> {
		const rows = this.all<{ serverName: string; enabled: number }>(
			`SELECT * FROM ${this.t.serverPermissions}`,
		);
		return rows.map(r => ({ serverName: r.serverName, enabled: r.enabled === 1 }));
	}

	// ============================================================
	// Permissions — tools
	// ============================================================
	async getToolPermission(serverName: string, toolName: string): Promise<IToolPermission | null> {
		const row = this.get<{ serverName: string; toolName: string; enabled: number; approvalMode: string }>(
			`SELECT * FROM ${this.t.toolPermissions} WHERE serverName = ? AND toolName = ?`, [serverName, toolName],
		);
		if (!row) return null;
		return {
			serverName: row.serverName,
			toolName: row.toolName,
			enabled: row.enabled === 1,
			approvalMode: row.approvalMode as EToolApprovalMode,
		};
	}

	async setToolPermission(serverName: string, toolName: string, enabled: boolean, approvalMode: EToolApprovalMode): Promise<void> {
		const exists = this.get(
			`SELECT 1 FROM ${this.t.toolPermissions} WHERE serverName = ? AND toolName = ?`,
			[serverName, toolName],
		);
		if (exists) {
			this.run(
				`UPDATE ${this.t.toolPermissions} SET enabled = ?, approvalMode = ? WHERE serverName = ? AND toolName = ?`,
				[enabled ? 1 : 0, approvalMode, serverName, toolName],
			);
		} else {
			this.run(
				`INSERT INTO ${this.t.toolPermissions} (serverName, toolName, enabled, approvalMode) VALUES (?, ?, ?, ?)`,
				[serverName, toolName, enabled ? 1 : 0, approvalMode],
			);
		}
	}

	async getAllToolPermissions(): Promise<IToolPermission[]> {
		const rows = this.all<{ serverName: string; toolName: string; enabled: number; approvalMode: string }>(
			`SELECT * FROM ${this.t.toolPermissions}`,
		);
		return rows.map(r => ({
			serverName: r.serverName,
			toolName: r.toolName,
			enabled: r.enabled === 1,
			approvalMode: r.approvalMode as EToolApprovalMode,
		}));
	}
}
