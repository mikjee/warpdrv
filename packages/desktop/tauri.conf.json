{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
	"productName": "WarpCore",
	"version": "0.1.2",
	"identifier": "com.warpcore.desktop",
	"build": {
		"devUrl": "http://localhost:3000",
		"frontendDist": "http://localhost:4400"
	},
	"app": {
		"windows": [
			{
				"title": "WarpCore",
				"width": 1100,
				"height": 750,
				"minWidth": 800,
				"minHeight": 600,
				"visible": false,
				"decorations": false,
				"resizable": true,
				"useHttpsScheme": true
			}
		],
		"security": {
			"csp": null
		},
		"trayIcon": {
			"iconPath": "icons/icon.png",
			"iconAsTemplate": false
		}
	},
	"bundle": {
		"active": true,
		"targets": [
			"appimage",
			"deb"
		],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/icon.ico",
			"icons/icon.png"
		],
		"externalBin": [
			"binaries/warpcore-server"
		],
		"resources": [
			"app-dist/**/*"
		],
		"linux": {
			"deb": {
				"depends": [
					"libwebkit2gtk-4.1-0",
					"libgtk-3-0",
					"libayatana-appindicator3-1"
				]
			}
		}
	},
	"plugins": {
		"shell": {
			"open": true
		}
	}
}
